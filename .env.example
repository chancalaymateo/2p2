# =========================================================================
# Configuracion de Remote-Desk. Copia este archivo a `.env` y ajusta.
# =========================================================================

# --- Servidor de senalizacion ---
SIGNALING_HOST=0.0.0.0
SIGNALING_PORT=8765

# URL que usan agente y controlador para conectarse al servidor.
# En produccion DEBE ser wss:// (TLS). ws:// solo para pruebas locales.
SIGNALING_URL=ws://127.0.0.1:8765

# --- TLS (produccion) ---
# Rutas a certificado y clave privada para habilitar wss://.
# Deja vacio para desarrollo local sin cifrado de transporte.
TLS_CERT_FILE=
TLS_KEY_FILE=

# --- Servidores ICE (para atravesar NAT/firewalls) ---
# STUN publico de Google por defecto. Para redes restrictivas agrega un TURN.
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=
TURN_USERNAME=
TURN_PASSWORD=

# --- Agente ---
# Si es "true" el agente pide confirmacion manual antes de aceptar cada
# conexion (recomendado por seguridad). "false" acepta automaticamente.
AGENT_REQUIRE_CONSENT=true

# --- Seguridad ---
# Maximos intentos de clave fallidos antes de bloquear temporalmente.
MAX_AUTH_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=60

# --- Auto-actualizacion ---
# Repositorio GitHub "usuario/repo" desde donde se revisan nuevas Releases.
GITHUB_REPO=chancalaymateo/2p2
UPDATE_CHECK_ENABLED=true
